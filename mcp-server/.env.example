# FieldTwin MCP Server — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your FieldTwin backend URL (no trailing slash)
FIELDTWIN_BACKEND_URL=https://backend.fieldtwin.com

# Your FieldTwin API token (account-level, from FieldTwin Settings → API Tokens)
# This is NOT the same as the JWT token from the loaded event.
FIELDTWIN_API_TOKEN=

# Optional: default subproject ID used when no subProjectId is passed to a tool
FIELDTWIN_SUBPROJECT_ID=
